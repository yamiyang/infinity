{
  "name": "wc-components",
  "version": "0.1.0",
  "description": "Natural-language-driven Web Components powered by LLM. Drop <wc-content>, <wc-table>, <wc-card> into any HTML — framework-free.",
  "type": "module",
  "main": "./dist/wc-components.cjs",
  "module": "./dist/wc-components.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/wc-components.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/wc-components.cjs"
      }
    },
    "./script": "./dist/wc-components.iife.js",
    "./inject": {
      "import": "./dist/inject.js",
      "require": "./dist/inject.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "ai",
    "llm",
    "natural-language",
    "streaming",
    "generative-ui",
    "framework-agnostic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/infinity"
  },
  "sideEffects": false
}
